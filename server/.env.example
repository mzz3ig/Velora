# ─── Stripe ────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Get from https://dashboard.stripe.com/webhooks after adding the endpoint
# Endpoint URL: https://api.yourdomain.com/stripe/webhook
# Events to listen for:
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER_MONTHLY=price_1TOQEAKSDoc3JnVcS7CWH66Z
STRIPE_PRICE_STARTER_YEARLY=price_1TOQVYKSDoc3JnVcSXTZWRJJ
STRIPE_PRICE_PRO_MONTHLY=price_1TOQEaKSDoc3JnVct2WRERBc
STRIPE_PRICE_PRO_YEARLY=price_1TOQVFKSDoc3JnVcUB9sY0kR
STRIPE_PRICE_STUDIO_MONTHLY=price_1TOQFAKSDoc3JnVcq7fKkCso
STRIPE_PRICE_STUDIO_YEARLY=price_1TOQUvKSDoc3JnVcjgkR261f

# ─── Supabase ───────────────────────────────────────────────────────────────
# Get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxx.supabase.co
# Use the SERVICE ROLE key (not anon) — this bypasses RLS for webhook writes
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App ────────────────────────────────────────────────────────────────────
# Your frontend URL (no trailing slash)
FRONTEND_URL=https://app.velora.com

# Optional: allow multiple frontend origins in production (comma-separated)
FRONTEND_URLS=https://app.velora.com,https://www.velora.com

# Admin emails (comma-separated). Used by backend `/admin/*` endpoints.
ADMIN_EMAILS=admin@example.com

PORT=4000
